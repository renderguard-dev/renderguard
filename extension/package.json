{
  "name": "renderguard",
  "displayName": "RenderGuard",
  "description": "Detect and fix unnecessary React re-renders — inline objects, missing memo, unstable deps, and more.",
  "version": "0.1.0",
  "publisher": "renderguard-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/renderguard-dev/renderguard"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "react",
    "re-render",
    "performance",
    "memo",
    "optimization"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "icon": "media/logo.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "renderguard",
          "title": "RenderGuard",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "renderguard": [
        {
          "id": "renderguard.componentTree",
          "name": "Component Risk"
        }
      ]
    },
    "commands": [
      {
        "command": "renderguard.refreshTree",
        "title": "RenderGuard: Refresh Component Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "renderguard.analyzeFile",
        "title": "RenderGuard: Analyze Current File"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "renderguard.refreshTree",
          "when": "view == renderguard.componentTree",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "RenderGuard",
      "properties": {
        "renderguard.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable RenderGuard diagnostics."
        },
        "renderguard.severity": {
          "type": "string",
          "default": "warning",
          "enum": [
            "error",
            "warning",
            "information",
            "hint"
          ],
          "description": "Severity level for RenderGuard diagnostics."
        },
        "renderguard.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show render risk scores above components."
        },
        "renderguard.patterns": {
          "type": "object",
          "default": {
            "inlineObjects": true,
            "inlineFunctions": true,
            "missingMemo": true,
            "unstableKeys": true,
            "unstableDeps": true,
            "broadContext": true,
            "derivedState": true,
            "propsDrilling": true,
            "liftedState": true
          },
          "description": "Enable or disable specific pattern detectors."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:prod": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "npm run build -- --watch",
    "vscode:prepublish": "cp ../assets/logo.png media/logo.png && cp ../README.md README.md && cp ../LICENSE LICENSE && npm run build:prod",
    "package": "vsce package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.13.4",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@babel/parser": "^7.26.7",
    "@babel/traverse": "^7.26.7",
    "@babel/types": "^7.26.7"
  }
}
